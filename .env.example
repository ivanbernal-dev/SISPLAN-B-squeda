# ============================================================
# UBPD — Variables de Entorno
# Copiar a .env y ajustar los valores antes del primer arranque
# NUNCA commitear el archivo .env al repositorio
# ============================================================

# ─── SERVIDOR ─────────────────────────────────────────────
# IP o host con el que accedes desde otros equipos (opcional). Si no aplica, usa 127.0.0.1
SERVER_IP=192.168.1.100
# Dominio local (opcional — solo si existe DNS en la intranet)
# SERVER_DOMAIN=ubpd.local

# ─── SEGURIDAD / JWT ──────────────────────────────────────
# Clave secreta para firmar JWT — CAMBIAR OBLIGATORIAMENTE
# Generar con: python3 -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=CAMBIAR_POR_CLAVE_ALEATORIA_MUY_LARGA_MINIMO_64_CARACTERES

# Algoritmo JWT
JWT_ALGORITHM=HS256

# Duración del access token en minutos
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Duración del refresh token en días
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── BASE DE DATOS — PostgreSQL ───────────────────────────
POSTGRES_USER=ubpd_user
POSTGRES_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO
POSTGRES_DB=ubpd_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ─── VALKEY — Broker de Celery y caché ───────────────────
VALKEY_HOST=valkey
VALKEY_PORT=6379
VALKEY_PASSWORD=CAMBIAR_POR_VALKEY_PASSWORD
VALKEY_DB=0

# ─── MINIO — Almacenamiento de Archivos ──────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=ubpd_minio_admin
MINIO_ROOT_PASSWORD=CAMBIAR_POR_MINIO_PASSWORD_MINIMO_8_CHARS
MINIO_BUCKET_NAME=ubpd-formularios
MINIO_USE_SSL=false

# URLs pre-signed: tiempo de validez en segundos (1 hora por defecto)
MINIO_PRESIGNED_URL_EXPIRY=3600

# ─── ARCHIVOS ────────────────────────────────────────────
# Tamaño máximo de archivo a subir (en MB)
MAX_UPLOAD_MB=50

# Tipos MIME permitidos para upload
ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,image/webp,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel

# ─── BACKEND — FastAPI ───────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Nombre de la aplicación (aparece en docs de API)
APP_NAME=UBPD - SISPLAN-Búsqueda
APP_VERSION=1.0.0

# Entorno: development | production
APP_ENV=production

# CORS: incluir TODAS las URLs con las que abras el navegador (mismo protocolo, host y puerto).
# Ej.: si entras por http://192.168.1.50, esa cadena debe estar aquí; incluye 127.0.0.1 y localhost.
CORS_ORIGINS=http://127.0.0.1,http://localhost,http://192.168.1.100,http://localhost:5173,http://localhost:3000

# ─── LOGGING ─────────────────────────────────────────────
# Directorio donde se guardan los logs (fuera del contenedor via volumen Docker)
# En Docker: /app/logs → montado en ./logs/backend del host
# En desarrollo local: cambiar a ./logs/backend (relativo al directorio backend/)
LOG_DIR=/app/logs

# Nivel de log: DEBUG | INFO | WARNING | ERROR
# En producción usar INFO; en desarrollo usar DEBUG
LOG_LEVEL=INFO

# ─── CELERY — Pipeline de Estadísticas ──────────────────
# Intervalo de recálculo periódico en segundos (10 minutos)
STATS_RECALC_INTERVAL_SECONDS=600

# Tiempo de retención de logs de pipeline en días
PIPELINE_LOG_RETENTION_DAYS=30

# ─── PRIMER USUARIO ADMIN ────────────────────────────────
# Solo se usa en el script de inicialización (scripts/create_admin.py)
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=CAMBIAR_POR_PASSWORD_INICIAL_SEGURO
INITIAL_ADMIN_NOMBRE=Administrador UBPD

INITIAL_ADMIN_EMAIL=admin@ubpd.gov.co

# ─── OPCIONES DE TRABAJO ─────────────────────────────────
# Permite resetear la base de datos con: ./scripts/prod.sh reset-db
# PELIGRO: elimina TODOS los datos. Mantener en false en producción real.
# Cambiar a true solo cuando se necesite una BD limpia durante desarrollo.
ALLOW_DB_RESET=false
