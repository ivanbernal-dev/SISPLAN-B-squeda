# ============================================================
# .gitignore — Sistema UBPD
# Solo se versiona código fuente, scripts, documentación y schemas.
# Datos, exportes, generated files y entornos locales quedan fuera.
# ============================================================

# ── Variables de entorno (NUNCA commitear) ──────────────────
.env
.env.local
.env.production
.env.*.local

# ── Certificados SSL ────────────────────────────────────────
nginx/certs/

# ── Dependencias Node ───────────────────────────────────────
# Dependencias y compilados de cualquier aplicacion web del repositorio.
# El package-lock.json de cada proyecto SI se versiona; los archivos internos
# node_modules/.package-lock.json NO se suben porque node_modules queda excluido.
node_modules/
**/node_modules/
dist/
**/dist/
frontend/.vite/

# ── Caché y entornos Python ─────────────────────────────────
**/__pycache__/
*.pyc
*.pyo
*.pyd
.Python
backend/.venv/
backend/venv/
.venv/
venv/
.ipynb_checkpoints/
analitica_bi/.venv/

# ── Wheels y vendor ─────────────────────────────────────────
vendor/
*.whl

# ── Migraciones generadas (opcional) ────────────────────────
# backend/alembic/versions/

# ── Artefactos Docker ───────────────────────────────────────
*.tar
*.tar.gz
docker-volumes/

# ── Backups y dumps de base de datos ────────────────────────
backups/
*.sql
*.sql.gz
*.dump

# ── Logs en tiempo de ejecución ─────────────────────────────
logs/

# ── IDEs y editores ─────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.lnk

# ── Sistema operativo ───────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Config local del asistente / herramientas ───────────────
.claude/

# ── Datos y archivos generados (NO son código) ─────────────
# Archivos Excel en cualquier ruta — generados o de carga, no versionar
*.xlsx
*.xlsm
*.xls
*.csv
# Pero sí queremos los ejemplos canónicos de scripts/pai_2026/examples/
!scripts/pai_2026/examples/*.xlsx
# Word, PDFs, PowerPoint generados (excepto docs/ que sí versionamos)
*.docx
*.pdf
*.pptx
!docs/**/*.docx
!docs/**/*.pdf
!docs/**/*.pptx

# ── Carpetas locales con datos / referencias / pruebas ─────
referencias/
referencias_BI/
DATOS_FORMULARIOS_2/
test-data/
analitica_bi/datos/
analitica_bi/output/

# ── MinIO / Postgres / Valkey volumes locales ──────────────
minio/data/
postgres/data/
valkey/data/

# ── Otros temporales ────────────────────────────────────────
*.tmp
*.bak
*.log
*.pid
tmp/
