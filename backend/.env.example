# Backend .env.example
# Las variables reales vienen del .env raíz vía docker-compose env_file
# Este archivo documenta las variables que el backend espera

SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

DATABASE_URL=postgresql+asyncpg://ubpd_user:password@postgres:5432/ubpd_db

VALKEY_URL=redis://:password@valkey:6379/0

MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=ubpd_minio_admin
MINIO_ROOT_PASSWORD=
MINIO_BUCKET_NAME=ubpd-formularios
MINIO_USE_SSL=false
MINIO_PRESIGNED_URL_EXPIRY=3600

MAX_UPLOAD_MB=50
ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel

APP_NAME=UBPD
APP_VERSION=1.0.0
APP_ENV=production

CORS_ORIGINS=http://192.168.1.100
